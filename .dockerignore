# ── .dockerignore ─────────────────────────────────────────────────────────────
# Files excluded from Docker build context.
# Smaller context = faster builds.

# Python
__pycache__/
*.py[cod]
*.pyo
.pytest_cache/
*.egg-info/

# Virtual environments
.venv/
venv/
env/

# Environment files — NEVER bake secrets into image
# Railway injects these as environment variables
.env
.env.*
!.env.example

# Data — persisted via Railway volume or mounted locally
data/
*.db
*.sqlite

# Development files
test_quick.py
*.txt
toml.txt

# Git
.git/
.gitignore

# IDE
.vscode/
.idea/
*.swp

# OS
.DS_Store
Thumbs.db

# Logs
*.log
logs/

# Node (just in case)
node_modules/
