# .dockerignore — tells Docker what NOT to copy into the build container
# Be VERY careful here — if you accidentally ignore too much,
# Docker gets an empty build context and can't find requirements.txt

# Virtual environment — never copy, Docker installs fresh from requirements.txt
.venv/
venv/
env/

# Python cache — not needed
__pycache__/
*.pyc
*.pyo
*.pyd

# Local data — SQLite db is ephemeral on HF anyway
data/
*.db

# Git
.git/
.gitignore

# Local dev files — not needed in production
.env
debug_therapist.py
deploy_to_hf.py
fix_hf_upload.py
docker-compose.yml
railway.toml

# Outputs and temp
*.pdf
*.log
_README_bak.md
HF_README.md