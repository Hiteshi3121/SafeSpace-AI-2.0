# ── LLM ──────────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here

# ── LLMOps ───────────────────────────────────────────
LANGSMITH_API_KEY=your_langsmith_api_key_here
LANGSMITH_PROJECT=safespace-ai
LANGSMITH_TRACING=true

# ── Twilio (WhatsApp + emergency call) ───────────────
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886
TWILIO_FROM_NUMBER=+14155238886
EMERGENCY_CONTACT=+91XXXXXXXXXX

# ── Google Maps (therapist finder) ───────────────────
GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# ── App settings ─────────────────────────────────────
APP_ENV=development          # development | production
APP_PORT=8000
LOG_LEVEL=INFO

# ── Memory ───────────────────────────────────────────
SQLITE_DB_PATH=./data/safespace.db
SESSION_MAX_MESSAGES=20      # max messages kept per user session
